{
  "name": "shortlist-backend",
  "version": "0.0.1",
  "description": "Shortlist — Indian car recommendation API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "build:scripts": "tsc scripts/seed.ts --outDir dist/scripts --esModuleInterop --skipLibCheck --moduleResolution node --target es2020",
    "seed:prod": "node dist/scripts/seed.js",
    "dev": "node -e \"const fs=require('fs');['dist','tsconfig.build.tsbuildinfo'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch{}})\" && nest start --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:agent": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@langchain/core": "1.1.40",
    "@langchain/google-vertexai": "2.1.27",
    "@langchain/langgraph": "1.2.9",
    "@nestjs/common": "11.0.1",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.0.1",
    "@nestjs/platform-express": "11.0.1",
    "@nestjs/throttler": "6.5.0",
    "@types/better-sqlite3": "7.6.13",
    "better-sqlite3": "12.9.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "24.0.0",
    "@types/supertest": "7.2.0",
    "eslint": "9.18.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "17.0.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "unplugin-swc": "1.5.1",
    "@swc/core": "1.10.1",
    "vitest": "3.2.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
