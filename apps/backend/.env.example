# Gemini / Vertex AI credentials (JSON string of GCP service account)
GEMINI_SERVICE_JSON=

# Optional: Gemini API key (not used by default, Vertex AI preferred)
GEMINI_API_KEY=

# Frontend origin for CORS (leave blank for default http://localhost:5173)
FRONTEND_URL=

# Server port (default: 3001)
PORT=3001

# SQLite database directory (default: ./data)
DB_DIR=
