# Backend server port
PORT=3001

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Directory where the SQLite database file is stored
DB_DIR=data

# Google Cloud service account credentials as a compact JSON string
# Download from GCP Console → IAM → Service Accounts → Keys
# Required roles: roles/aiplatform.user (Vertex AI User)
GEMINI_SERVICE_JSON=

# LangSmith observability (optional — traces all LangChain/LangGraph calls)
# Get your API key at https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=shortlist-backend
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
